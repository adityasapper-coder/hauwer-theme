<a href="{{ product.url }}" class="product-card" data-shine-card>
  <div class="product-card-img" data-shine-wrap>
    <div class="card-shine" data-shine></div>

    <div style="position:absolute;top:12px;left:12px;z-index:10;">
      {%- if product.tags contains 'new' or product.tags contains 'New' -%}
        <span class="tag-pill" style="color:#C5F700;border-color:#C5F700;">NEW DROP</span>
      {%- elsif product.tags contains 'bestseller' -%}
        <span class="tag-pill" style="color:#fff;border-color:rgba(255,255,255,.4);">BESTSELLER</span>
      {%- elsif product.tags contains 'limited' -%}
        <span class="tag-pill" style="color:#C5F700;border-color:#C5F700;">LIMITED</span>
      {%- else -%}
        <span class="tag-pill" style="color:rgba(255,255,255,.5);border-color:rgba(255,255,255,.2);">SS26</span>
      {%- endif -%}
    </div>

    {%- if product.compare_at_price > product.price -%}
      {%- assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
      <div style="position:absolute;top:12px;right:12px;z-index:10;background:var(--orange);color:#fff;font-family:var(--font-body);font-weight:700;font-size:.58rem;padding:4px 8px;border-radius:2px;">-{{ discount }}%</div>
    {%- endif -%}

    {%- if product.featured_image -%}
      <img src="{{ product.featured_image | img_url: '600x800', crop: 'center' }}" alt="{{ product.title | escape }}" width="600" height="800" loading="lazy" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;">
      {%- if product.images[1] -%}
        <img src="{{ product.images[1] | img_url: '600x800', crop: 'center' }}" alt="{{ product.title | escape }}" width="600" height="800" loading="lazy" class="product-card-hover-img" style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0;opacity:0;transition:opacity .5s var(--ease);">
      {%- endif -%}
    {%- else -%}
      <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#1a1a1a 0%,#2d2d2d 50%,#111 100%);">
        <span style="font-family:var(--font-head);color:rgba(255,255,255,.04);font-size:clamp(4rem,8vw,7rem);user-select:none;">{{ product.title | split: ' ' | first }}</span>
      </div>
    {%- endif -%}

    <div class="product-card-quick-add">
      <button type="button" data-quick-add="{{ product.variants.first.id }}">QUICK ADD</button>
    </div>
  </div>

  <div style="padding:12px;background:var(--bg-2);display:flex;flex-direction:column;gap:8px;">
    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;">
      <div>
        <p style="font-family:var(--font-body);color:var(--muted);font-size:.5rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;margin-bottom:4px;">{{ product.type | default: 'APPAREL' }}</p>
        <h3 style="font-family:var(--font-body);color:var(--text);font-weight:600;font-size:14px;line-height:1.3;">{{ product.title }}</h3>
      </div>
      <div style="display:flex;flex-direction:column;align-items:flex-end;flex-shrink:0;">
        <span style="font-family:var(--font-body);color:var(--text);font-weight:700;font-size:14px;">{{ product.price | money }}</span>
        {%- if product.compare_at_price > product.price -%}
          <span style="font-family:var(--font-body);color:var(--muted);font-size:12px;text-decoration:line-through;">{{ product.compare_at_price | money }}</span>
        {%- endif -%}
      </div>
    </div>
    {%- assign size_opt = product.options_with_values | where: 'name', 'Size' | first -%}
    {%- if size_opt -%}
      <div style="display:flex;gap:4px;flex-wrap:wrap;padding-top:4px;">
        {%- for v in size_opt.values limit: 4 -%}
          <span style="font-family:var(--font-body);color:var(--muted);font-size:.55rem;border:1px solid var(--border);padding:2px 6px;">{{ v }}</span>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</a>
