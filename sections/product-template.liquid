<div class="product-page container">
  <div class="product-layout">

    <!-- LEFT: Gallery -->
    <div class="product-gallery" id="product-gallery">
      <div class="product-gallery__main">
        <img
          id="product-featured-image"
          class="product-gallery__featured"
          src="{{ product.featured_image | img_url: '900x1100', crop: 'center' }}"
          alt="{{ product.featured_image.alt | default: product.title | escape }}"
          width="900" height="1100"
          loading="eager">
      </div>
      {%- if product.images.size > 1 -%}
        <div class="product-gallery__thumbs" id="product-thumbs">
          {%- for image in product.images -%}
            <button
              type="button"
              class="gallery-thumb{% if forloop.first %} active{% endif %}"
              data-img-src="{{ image | img_url: '900x1100', crop: 'center' }}"
              data-img-alt="{{ image.alt | default: product.title | escape }}"
              aria-label="View image {{ forloop.index }}">
              <img src="{{ image | img_url: '120x150', crop: 'center' }}" alt="{{ image.alt | escape }}" width="80" height="100" loading="lazy">
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- RIGHT: Info -->
    <div class="product-info">

      <!-- Breadcrumb -->
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span>›</span>
        {%- for collection in product.collections limit: 1 -%}
          <a href="{{ collection.url }}">{{ collection.title }}</a>
          <span>›</span>
        {%- endfor -%}
        <span aria-current="page">{{ product.title }}</span>
      </nav>

      <h1 class="product-info__title">{{ product.title }}</h1>

      <!-- Price -->
      <div class="product-info__price" id="product-price">
        {%- if product.compare_at_price > product.price -%}
          <span class="price price--sale">{{ product.price | money }}</span>
          <span class="price price--compare">{{ product.compare_at_price | money }}</span>
          {%- assign savings = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
          <span class="price-badge">({{ savings }}% OFF)</span>
        {%- else -%}
          <span class="price">{{ product.price | money }}</span>
        {%- endif -%}
        <span class="price-tax-note">Incl. of all taxes</span>
      </div>

      {%- unless product.has_only_default_variant -%}
      <form action="/cart/add" method="post" enctype="multipart/form-data" id="product-form">
        <input type="hidden" name="form_type" value="product">
        <input type="hidden" name="utf8" value="✓">
        <input type="hidden" name="id" id="product-variant-id" value="{{ product.selected_or_first_available_variant.id }}">

        {%- for option in product.options_with_values -%}
          {%- assign opt_down = option.name | downcase -%}
          <div class="product-option" data-option-index="{{ forloop.index0 }}">
            <div class="product-option__head">
              <span class="product-option__name">{{ option.name | upcase }}:</span>
              <span class="product-option__selected" id="option-selected-{{ forloop.index0 }}">{{ option.selected_value }}</span>
            </div>

            {%- if opt_down == 'color' or opt_down == 'colour' -%}
              <div class="product-option__values product-option__values--colors" role="radiogroup" aria-label="{{ option.name }}">
                {%- for value in option.values -%}
                  <label class="color-swatch-label" title="{{ value }}">
                    <input
                      type="radio"
                      name="option_{{ forloop.parentloop.index0 }}"
                      value="{{ value | escape }}"
                      class="product-option__radio"
                      {% if option.selected_value == value %}checked{% endif %}
                      data-option-index="{{ forloop.parentloop.index0 }}"
                      data-option-value="{{ value | escape }}">
                    <span
                      class="color-swatch"
                      style="background-color:{{ value | downcase | replace: ' ', '' }};">
                    </span>
                  </label>
                {%- endfor -%}
              </div>

            {%- elsif opt_down == 'size' -%}
              <div class="product-option__values" role="radiogroup" aria-label="{{ option.name }}">
                {%- for value in option.values -%}
                  {%- assign variant_available = false -%}
                  {%- for variant in product.variants -%}
                    {%- if variant.title contains value and variant.available -%}
                      {%- assign variant_available = true -%}
                    {%- endif -%}
                  {%- endfor -%}
                  <label class="size-btn-label{% unless variant_available %} size-btn-label--unavailable{% endunless %}">
                    <input
                      type="radio"
                      name="option_{{ forloop.parentloop.index0 }}"
                      value="{{ value | escape }}"
                      class="product-option__radio"
                      {% if option.selected_value == value %}checked{% endif %}
                      {% unless variant_available %}disabled{% endunless %}
                      data-option-index="{{ forloop.parentloop.index0 }}"
                      data-option-value="{{ value | escape }}">
                    <span class="size-btn">{{ value }}</span>
                  </label>
                {%- endfor -%}
              </div>
              {%- if section.settings.size_guide_url != blank -%}
                <a href="{{ section.settings.size_guide_url }}" class="size-guide-link" target="_blank">Size Guide →</a>
              {%- endif -%}

            {%- else -%}
              <div class="product-option__values" role="radiogroup">
                {%- for value in option.values -%}
                  <label class="size-btn-label">
                    <input type="radio" name="option_{{ forloop.parentloop.index0 }}" value="{{ value | escape }}" class="product-option__radio" {% if option.selected_value == value %}checked{% endif %} data-option-index="{{ forloop.parentloop.index0 }}" data-option-value="{{ value | escape }}">
                    <span class="size-btn">{{ value }}</span>
                  </label>
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}

        <!-- Availability -->
        <p class="product-availability" id="product-availability">
          {%- if product.selected_or_first_available_variant.available -%}
            <span class="avail avail--in">● In Stock</span>
          {%- else -%}
            <span class="avail avail--out">● Out of Stock</span>
          {%- endif -%}
        </p>

        <!-- Quantity -->
        <div class="product-qty">
          <label class="product-qty__label">QTY</label>
          <div class="qty-selector">
            <button type="button" class="qty-selector__btn" data-action="minus" aria-label="Decrease">−</button>
            <input type="number" name="quantity" id="product-qty" value="1" min="1" max="10" class="qty-selector__input" aria-label="Quantity">
            <button type="button" class="qty-selector__btn" data-action="plus" aria-label="Increase">+</button>
          </div>
        </div>

        <!-- ATC Button -->
        <div class="product-form__btns">
          <button
            type="submit"
            class="btn btn--primary btn--full btn--xl"
            id="add-to-cart-btn"
            {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}>
            {%- if product.selected_or_first_available_variant.available -%}
              ADD TO BAG
            {%- else -%}
              SOLD OUT
            {%- endif -%}
          </button>
        </div>

      </form>
      {%- else -%}
        <form action="/cart/add" method="post" id="product-form">
          <input type="hidden" name="id" value="{{ product.first_available_variant.id }}">
          <input type="hidden" name="quantity" value="1">
          <button type="submit" class="btn btn--primary btn--full btn--xl">ADD TO BAG</button>
        </form>
      {%- endunless -%}

      <!-- Trust badges -->
      <div class="product-trust">
        <div class="trust-badge">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          Free Shipping above ₹999
        </div>
        <div class="trust-badge">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 2l3 6 7 1-5 5 1 7-6-3-6 3 1-7-5-5 7-1 3-6z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
          7-Day Easy Returns
        </div>
        <div class="trust-badge">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><rect x="3" y="11" width="18" height="11" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M7 11V7a5 5 0 0110 0v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          Secure Checkout
        </div>
      </div>

      <!-- Description accordion -->
      <div class="product-accordion">
        <button type="button" class="accordion-trigger" aria-expanded="true">
          DESCRIPTION
          <svg class="accordion-icon" width="12" height="12" viewBox="0 0 12 8" fill="none">
            <path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
        <div class="accordion-body" id="description-body">
          <div class="product-description rte">
            {{ product.description }}
          </div>
        </div>
      </div>

      {%- if section.settings.show_shipping_info -%}
      <div class="product-accordion">
        <button type="button" class="accordion-trigger" aria-expanded="false">
          SHIPPING & RETURNS
          <svg class="accordion-icon" width="12" height="12" viewBox="0 0 12 8" fill="none">
            <path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
        <div class="accordion-body" hidden>
          <div class="rte">
            {{ section.settings.shipping_info }}
          </div>
        </div>
      </div>
      {%- endif -%}

    </div>
  </div>

  <!-- Related Products -->
  {%- assign related = collections[product.collections.first.handle].products -%}
  {%- if related.size > 1 -%}
  <section class="related-products section-padding">
    <h2 class="section-title">YOU MAY ALSO LIKE</h2>
    <div class="product-grid product-grid--4">
      {%- for rp in related limit: 4 -%}
        {%- unless rp.handle == product.handle -%}
          {%- render 'product-card', product: rp -%}
        {%- endunless -%}
      {%- endfor -%}
    </div>
  </section>
  {%- endif -%}
</div>

<script type="application/json" id="product-variants-json">
  {{ product.variants | json }}
</script>

{% schema %}
{
  "name": "Product",
  "settings": [
    {
      "type": "url",
      "id": "size_guide_url",
      "label": "Size guide URL"
    },
    {
      "type": "checkbox",
      "id": "show_shipping_info",
      "label": "Show shipping & returns accordion",
      "default": true
    },
    {
      "type": "richtext",
      "id": "shipping_info",
      "label": "Shipping & returns text",
      "default": "<p>Free shipping on orders above ₹999. Standard delivery in 3-5 business days. Easy 7-day returns on unworn items.</p>"
    }
  ],
  "presets": [{ "name": "Product" }]
}
{% endschema %}
