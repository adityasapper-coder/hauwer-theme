<section class="hero{% if section.settings.full_height %} hero--full{% endif %}" style="{% if section.settings.bg_image != blank %}background-image:url('{{ section.settings.bg_image | img_url: '2000x' }}');{% else %}background-color:{{ section.settings.bg_color }};{% endif %}">
  <div class="hero__overlay" style="opacity:{{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
  <div class="hero__content hero__content--{{ section.settings.text_align }}">
    {%- if section.settings.label != blank -%}
      <p class="hero__label">{{ section.settings.label }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h1 class="hero__heading" style="color:{{ section.settings.heading_color }};">{{ section.settings.heading }}</h1>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="hero__sub" style="color:{{ section.settings.subheading_color }};">{{ section.settings.subheading }}</p>
    {%- endif -%}
    {%- if section.settings.btn_text != blank -%}
      <a href="{{ section.settings.btn_link }}" class="btn btn--primary btn--lg">{{ section.settings.btn_text }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color (fallback)",
      "default": "#111010"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 40
    },
    {
      "type": "checkbox",
      "id": "full_height",
      "label": "Full viewport height",
      "default": true
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Small label above heading",
      "default": "SS26 COLLECTION"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "WEAR THE\nSTREETS"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#f0ede6"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Premium streetwear from Delhi."
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#f0ede6"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button link"
    }
  ],
  "presets": [{ "name": "Hero Banner" }]
}
{% endschema %}
