<section class="hero" id="hero">
  <div class="hero__grid-bg" aria-hidden="true"></div>
  <div class="hero__bg-text" aria-hidden="true">SS26</div>

  <div class="hero__inner">

    <!-- LEFT: Typography -->
    <div>
      <div class="hero__meta" id="hero-meta">
        <span class="hero__meta-line"></span>
        <span class="label-text" style="color:var(--orange);font-size:.58rem;">SS26 COLLECTION</span>
        <span style="color:var(--muted);">·</span>
        <span class="label-text" style="color:var(--mid);font-size:.58rem;">100% COTTON</span>
        <span style="color:var(--muted);">·</span>
        <span class="label-text" style="color:var(--mid);font-size:.58rem;">DELHI</span>
      </div>

      <h1 class="hero__heading" id="hero-heading">
        <div>
          {%- for char in 'BUILT' | split: '' -%}
            <span class="hero__char"><span class="hero__char-inner">{{ char }}</span></span>
          {%- endfor -%}
        </div>
        <div>
          {%- for char in 'DIFFER' | split: '' -%}
            <span class="hero__char"><span class="hero__char-inner">{{ char }}</span></span>
          {%- endfor -%}
        </div>
        <div class="orange">
          {%- for char in 'ENT.' | split: '' -%}
            <span class="hero__char"><span class="hero__char-inner" style="color:var(--orange);">{{ char }}</span></span>
          {%- endfor -%}
        </div>
      </h1>

      <div class="hero__cta-wrap" id="hero-cta">
        <p class="hero__cta-desc">Engineered for the streets. Premium cotton built to last every season.</p>
        <div class="hero__cta-btns">
          <a href="/collections/all" class="btn btn-primary">
            SHOP NOW
            <svg width="13" height="13" viewBox="0 0 14 14" fill="none">
              <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </a>
          <a href="#story" class="btn btn-outline">EXPLORE</a>
        </div>
        <div class="hero__trust">
          <span class="hero__trust-item"><span class="hero__trust-dot"></span>Free Shipping ₹999+</span>
          <span class="hero__trust-item"><span class="hero__trust-dot"></span>7-Day Returns</span>
          <span class="hero__trust-item"><span class="hero__trust-dot"></span>Premium Cotton</span>
        </div>
      </div>
    </div>

    <!-- RIGHT: CSS Orb -->
    <div class="hero__orb-side">
      <div class="hero__orb-outer-ring"></div>

      <div class="orb-wrap" style="height:clamp(320px,45vw,580px);">
        <div class="orb">
          <div class="orb-inner"></div>
        </div>
      </div>

      <div class="hero__float-tag hero__float-tag--tl">
        <div style="background:rgba(255,255,255,.8);backdrop-filter:blur(8px);border:1px solid var(--border);border-radius:2px;padding:8px 16px;box-shadow:0 4px 16px rgba(17,16,16,.06);">
          <p class="hero__float-tag tag-name">TACTICAL CARGO</p>
          <p class="hero__float-tag tag-price">₹4,999</p>
        </div>
        <span class="tag-pill" style="color:var(--orange);border-color:var(--orange);font-size:.5rem;">LIMITED DROP</span>
      </div>

      <div class="hero__float-tag hero__float-tag--bl">
        <p style="font-family:var(--font-body);font-size:.5rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:4px;">NEW ARRIVAL</p>
        <p style="font-family:var(--font-body);color:var(--text);font-weight:600;font-size:12px;">OVERSIZED TEE</p>
      </div>
    </div>

  </div>

  <!-- Scroll indicator -->
  <div class="hero__scroll" aria-hidden="true">
    <div class="hero__scroll-line">
      <div class="hero__scroll-dot"></div>
    </div>
    <span class="label-text" style="color:var(--muted);font-size:.48rem;">SCROLL</span>
  </div>
</section>

<script>
(function(){
  function animateHero(){
    var chars = document.querySelectorAll('#hero-heading .hero__char-inner');
    var meta  = document.getElementById('hero-meta');
    var cta   = document.getElementById('hero-cta');
    if(typeof gsap !== 'undefined'){
      gsap.to(chars, { y: 0, duration: 1.1, stagger: .04, ease: 'power4.out', delay: .15 });
      gsap.to([meta, cta], { opacity: 1, y: 0, duration: .9, stagger: .15, ease: 'power3.out', delay: .7 });
    } else {
      // Fallback: CSS reveal
      setTimeout(function(){
        chars.forEach(function(c){ c.style.transform = 'translateY(0)'; c.style.transition = 'transform 1s cubic-bezier(.16,1,.3,1)'; });
        meta.classList.add('visible');
        cta.classList.add('visible');
      }, 150);
    }
  }
  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', animateHero);
  } else {
    animateHero();
  }
})();
</script>

{% schema %}
{
  "name": "Hero",
  "settings": []
}
{% endschema %}
