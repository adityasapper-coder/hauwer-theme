<div class="stats-row">
  <div class="stat-cell reveal reveal-d1">
    <span class="stat-value">100%</span>
    <span class="stat-label">PREMIUM COTTON</span>
  </div>
  <div class="stat-cell reveal reveal-d2">
    <span class="stat-value">2K+</span>
    <span class="stat-label">ORDERS SHIPPED</span>
  </div>
  <div class="stat-cell reveal reveal-d3">
    <span class="stat-value">SS26</span>
    <span class="stat-label">CURRENT SEASON</span>
  </div>
  <div class="stat-cell reveal reveal-d4">
    <span class="stat-value">DEL</span>
    <span class="stat-label">MADE IN DELHI</span>
  </div>
</div>

{% schema %}
{
  "name": "Stats Row",
  "settings": [],
  "presets": [{ "name": "Stats Row" }]
}
{% endschema %}
